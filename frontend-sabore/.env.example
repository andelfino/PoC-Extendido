# URL base del backend Java.
# Copia este archivo como .env.local y cambia el valor si tu backend
# corre en otro puerto o máquina.
VITE_API_BASE_URL=http://localhost:8080

# Client ID de tu app PayPal (sandbox).
# Obtenelo en https://developer.paypal.com → Apps & Credentials → Sandbox.
# Si lo dejás vacío, el botón PayPal muestra "no configurado" sin romper la app.
VITE_PAYPAL_CLIENT_ID=
